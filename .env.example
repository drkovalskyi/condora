# Condora Configuration
# Copy to .env and fill in real values. .env is gitignored.

# Database (required)
CONDORA_DATABASE_URL=postgresql+asyncpg://condora:CHANGEME@localhost:5432/condora

# User identity (required for test/global pool mode)
CONDORA_ACCOUNTING_GROUP_USER=CHANGEME
CONDORA_TEST_LFN_USER=CHANGEME.condora
CONDORA_RUCIO_TEST_ACCOUNT=CHANGEME

# HTCondor
CONDORA_CONDOR_HOST=localhost:9618
CONDORA_EXTRA_COLLECTORS=
CONDORA_REMOTE_SCHEDD=
CONDORA_SEC_TOKEN_DIRECTORY=

# Remote schedd spool access
CONDORA_SPOOL_MOUNT=
CONDORA_REMOTE_SPOOL_PREFIX=

# Service
CONDORA_DB_POOL_SIZE=10
CONDORA_LIFECYCLE_CYCLE_INTERVAL=60
CONDORA_MAX_ACTIVE_DAGS=300
CONDORA_API_PREFIX=/api/v1
CONDORA_LOG_LEVEL=INFO
CONDORA_DEBUG=false
